<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@android:color/black">

    <TextView
        android:id="@+id/widget_location_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#88FFFFFF"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_hijri_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginTop="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">
        <TextView
            android:id="@+id/widget_sunrise_label"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#FF9800"
            android:textSize="11sp" />
        <TextView
            android:id="@+id/widget_sunrise_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="2dp">
        <TextView
            android:id="@+id/widget_sunset_label"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:textColor="#2196F3"
            android:textSize="11sp" />
        <TextView
            android:id="@+id/widget_sunset_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_gregorian_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#88FFFFFF"
        android:textSize="11sp"
        android:layout_marginTop="4dp" />

</LinearLayout>
